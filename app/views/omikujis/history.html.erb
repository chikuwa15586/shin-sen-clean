<div class="page-container history-page">
  <% if @results.any? %>

  <h3 class="page-title">神籤の履歴</h3>

    <% @results.each do |result| %>

      <div class="history-card">

        <div class="history-row">

          <div class="history-image">
            <%= image_tag result.fortune.image, width: 90 %>
          </div>

          <div class="history-info">

            <div class="history-date">
              <%= result.created_at.strftime("%m月%d日") %>
            </div>

            <div class="history-result">
              <%= result.fortune.name %>
            </div>

            <div class="history-tasks">

              <% result.task_completions.each do |tc| %>

                <div class="history-task">

                  <span class="task-title">
                    <%= tc.task.title %>
                  </span>

                  <% if tc.completed %>

                    <span class="task-done">
                      🔴 達成！
                    </span>

                  <% else %>

                    <span class="task-undone">
                      ✘ 未達成
                    </span>

                  <% end %>

                </div>

              <% end %>

            </div>

          </div>

        </div>

      </div>

    <% end %>

  <% else %>

    <p class="no-history">まだ履歴がありません</p>

  <% end %>
</div>

<div class="history-back">
  <%= link_to "ホームへ戻る", home_path, class: "btn btn-japanese" %>

  <%= link_to "実績データ",
      users_stats_path,
      class: "btn btn-rare" %>
</div>