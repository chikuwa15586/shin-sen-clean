<% if @result.present? %>

<div class="result-container">

  <!-- 神籤カード -->
  <div class="draw-wrapper">
    <button id="omikuji-card" class="omikuji-card">
      ✨ タップして神籤を開く ✨
    </button>
  </div>

  <!-- 結果表示 -->
  <div id="omikuji-result"
      class="fortune-result rarity-<%= @result.fortune.rarity %>"
      data-rarity="<%= @result.fortune.rarity %>"
      style="display:none;">

      <h1 class="page-title">神籤の結果</h1>
      
      <p class="rarity-message">
        <%= @result.fortune.message %>
      </p>

      <div class="god-light"></div>

      <%= image_tag @result.fortune.image,
                    id: "omikuji-image",
                    class: "character-image" %>

      <% @result.task_completions.each do |tc| %>

        <div class="main-card result-card">

          <h3 class="mission-title">🌠星の導き -今日のタスク-</h3>

          <div class="task-title">
            <%= tc.task.title %>
          </div>

          <div class="task-content">
            <%= tc.task.content %>
          </div>

        </div>

      <% end %>

      <p class="notice-text">
        ※ 神籤は1日1回のみ引くことができます
      </p>

      <div class="result-buttons" style="display:none;">
        <%= link_to "ホームへ戻る", home_path, class: "btn btn-japanese" %>
      </div>

  </div>

</div>

<% else %>

<div class="result-container">

  <div class="result-buttons">
    <p class="error-text">
      本日はまだ神籤を引いていません。
    </p>

    <%= link_to "ホームへ戻る", root_path, class: "btn btn-japanese" %>
  </div>

</div>

<% end %>