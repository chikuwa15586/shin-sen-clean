<% if @result.present? %>

  <h1 style="text-align:center;">神籤の結果</h1>

  <p style="text-align:center; margin-top:0.5rem; color:#666;">
    ※ 神籤は1日1回のみ引くことができます
  </p>

  <!-- 神籤カード -->
  <div id="omikuji-card" class="omikuji-card">
    ✨ タップして神籤を開く ✨
  </div>

  <!-- 結果表示 -->
  <div id="omikuji-result"
       class="fortune-result rarity-<%= @result.rarity %>"
       data-rarity="<%= @result.rarity %>"
       style="display:none;">

    <div class="god-light"></div>
    
    <p id="omikuji-name" class="fortune-text">
      <strong><%= @result.result %></strong>
    </p>

    <%= image_tag @result.image,
                  id: "omikuji-image",
                  class: "character-image" %>

  </div>

  <!-- トップへ戻る -->
  <div style="text-align:center; margin-top:3rem;">
    <%= link_to "トップページへ", root_path, class: "btn btn-primary" %>
  </div>

<% else %>

  <div style="text-align:center; margin-top:2rem;">
    <p style="color:red;">
      本日はまだ神籤を引いていません。
    </p>

    <%= link_to "トップページへ戻る", root_path, class: "btn btn-secondary" %>
  </div>

<% end %>
