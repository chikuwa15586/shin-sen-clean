<% if @result.present? %>

  <h1 style="text-align:center;">神籤の結果</h1>

  <p style="text-align:center; margin-top:0.5rem; color:#666;">
    ※ 神籤は1日1回のみ引くことができます
  </p>

  <!-- 神籤カード（タップで開く） -->
  <div id="omikuji-card"
       style="cursor:pointer;
              text-align:center;
              margin:2rem auto;
              font-size:1.5rem;
              border:2px dashed #ccc;
              padding:2rem;
              border-radius:10px;
              max-width:400px;">
    ✨ タップして神籤を開く ✨
  </div>

  <!-- 結果表示 -->
  <div id="omikuji-result"
       style="display:none;
              text-align:center;
              margin-top:2rem;">

    <p id="omikuji-name"
       style="font-size: 1.8rem; margin-bottom:1rem;">
      <strong><%= @result.result %></strong>
    </p>

    <%= image_tag @result.image,
                  id: "omikuji-image",
                  style: "max-width:220px; border-radius:10px;" %>
  </div>

  <!-- トップへ戻る -->
  <div style="text-align:center; margin-top:3rem;">
    <%= link_to "トップページへ", root_path, class: "btn btn-primary" %>
  </div>

  <!-- 演出JS -->
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const card = document.getElementById("omikuji-card");
      const resultDiv = document.getElementById("omikuji-result");
      const nameEl = document.getElementById("omikuji-name");
      const imageEl = document.getElementById("omikuji-image");

      card.addEventListener("click", () => {

        // カード非表示
        card.style.display = "none";

        // 結果表示
        resultDiv.style.display = "block";

        // SE再生（public/sounds/chime.mp3）
        const audio = new Audio("/sounds/chime.mp3");
        audio.play();

        const resultName = "<%= @result.result %>";

        // 神吉だけ特別演出
        if(resultName === "神吉") {

          nameEl.style.fontSize = "3rem";
          nameEl.style.color = "gold";
          nameEl.style.textShadow = "0 0 20px gold";

          imageEl.style.transform = "scale(1.6)";
          imageEl.style.transition = "transform 1.2s ease";
          imageEl.style.boxShadow = "0 0 40px gold";

          document.body.style.backgroundColor = "#111";
        }
      });
    });
  </script>

<% else %>

  <div style="text-align:center; margin-top:2rem;">
    <p style="color:red;">
      本日はまだ神籤を引いていません。
    </p>

    <%= link_to "トップページへ戻る", root_path, class: "btn btn-secondary" %>
  </div>

<% end %>
