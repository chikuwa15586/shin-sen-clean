<div class="page-container">

  <div class="auth-page"> 

    <div class="auth-card">

      <h2 class="auth-title">ログイン</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>

        <div class="field">
          <%= f.label :email, "メールアドレス" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-field" %>
        </div>

        <div class="field">
          <%= f.label :password, "パスワード" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input-field" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="remember-field">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, "ログイン状態を保持" %>
          </div>
        <% end %>

        <div class="actions">
          <%= f.submit "ログイン", class: "btn btn-japanese" %>
        </div>

      <% end %>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>

    </div>

  </div>

</div>